# Copia questo file in .env.local e compila i valori reali.
# .env.local NON va mai committato (è già in .gitignore).

# --- Supabase ---
# Progetto Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# service_role key: SOLO lato server, mai esposta al browser. Serve per
# leggere le push_subscriptions e inviare le notifiche (Prompt 6).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Anthropic (lettura del foglio turni con IA visione) ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
# Opzionale: modello Claude con visione da usare per leggere il foglio turni.
CLAUDE_VISION_MODEL=claude-sonnet-5

# --- Web Push (VAPID) — notifiche push per l'admin (Prompt 6) ---
# Genera con: npm install && npm run generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:tuamail@esempio.com
