# Copia questo file in .env.local e compila i valori reali.
# .env.local NON va mai committato (è già in .gitignore).

# --- Supabase ---
# Progetto Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# service_role key: SOLO lato server, mai esposta al browser. Serve per
# leggere le push_subscriptions e inviare le notifiche (Prompt 6).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Groq (lettura del foglio turni con IA visione, gratuito) ---
# https://console.groq.com/keys
GROQ_API_KEY=gsk_...
# Opzionale: modello Groq con visione da usare per leggere il foglio turni.
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Web Push (VAPID) — notifiche push per l'admin (Prompt 6) ---
# Genera con: npm install && npm run generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:tuamail@esempio.com

# --- Google Calendar (sync automatica delle prenotazioni confermate) ---
# Vedi README per come creare l'account di servizio e condividere il calendario.
GOOGLE_SERVICE_ACCOUNT_EMAIL=xxx@xxx.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=tuamail@gmail.com
